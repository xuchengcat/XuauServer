    {
        "id": "782c815c81993b9c",
        "type": "function",
        "z": "783a4e34d3609ab4",
        "name": "生成sensor",
        "func": "const prefix = \"home/button/byd_car\"\nlet msg_config = [], car_info = msg.payload.data\nmsg_config = [\n    {\n        \"topic\": \"homeassistant/sensor/byd_car/config\",\n        \"payload\": {\n            \"~\": prefix.replace(\"button\", \"sensor\"),\n            \"name\": \"BYD_CAR\",\n            \"state_topic\": \"~/state\",\n            \"unique_id\": \"bydcar\",\n            \"icon\": \"mdi:car\",\n            \"json_attributes_topic\": \"~/info\"\n        }\n    },\n    {//整车状态 \n        \"topic\": \"homeassistant/sensor/byd_car_zczt/config\",\n        \"payload\": {\n            \"~\": prefix.replace(\"button\", \"sensor\"),\n            \"name\": \"BYD_CAR_ZCZT\",\n            \"state_topic\": \"~/zczt/state\",\n            \"unique_id\": \"byd_car_zczt\",\n            \"icon\": \"mdi:car\"\n        }\n    },\n    {//左前门状态\n        \"topic\": \"homeassistant/binary_sensor/byd_car_cmzq/config\",\n        \"payload\": {\n            \"~\": prefix.replace(\"button\", \"binary_sensor\"),\n            \"name\": \"BYD_CAR_CMZQ\",\n            \"state_topic\": \"~/cmzq/state\",\n            \"payload_on\": 1,\n            \"payload_off\": 0,\n            \"unique_id\": \"byd_car_cmzq\",\n            \"icon\": \"mdi:car-door-lock\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_door_lock/config\",\n        \"payload\": {\n            \"name\": \"byd_car_door_lock\",//车门上锁\n            \"command_topic\": `${prefix}/door_lock/control`,\n            \"payload_press\": \"8F14E45FCEEA167A5A36DEDD4BEA2543\",\n            \"unique_id\": \"byd_car_door_lock\",\n            \"icon\": \"mdi:car-door-lock\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_door_unlock/config\",\n        \"payload\": {\n            \"name\": \"byd_car_door_unlock\",//车门解锁\n            \"command_topic\": `${prefix}/door_unlock/control`,\n            \"payload_press\": \"E4DA3B7FBBCE2345D7772B0674A318D5\",\n            \"unique_id\": \"byd_car_door_unlock\",\n            \"icon\": \"mdi:car-door\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_turnon_aircondition/config\",\n        \"payload\": {\n            \"name\": \"byd_car_turnon_aircondition\",//开启空调\n            \"command_topic\": `${prefix}/turnon_aircondition/control`,\n            \"payload_press\": \"ECCBC87E4B5CE2FE28308FD9F2A7BAF3\",\n            \"unique_id\": \"byd_car_turnon_aircondition\",\n            \"icon\": \"mdi:hvac\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_turnoff_aircondition/config\",\n        \"payload\": {\n            \"name\": \"byd_car_turnoff_aircondition\",//关闭空调\n            \"command_topic\": `${prefix}/turnoff_aircondition/control`,\n            \"payload_press\": \"45C48CCE2E2D7FBDEA1AFC51C7C6AD26\",\n            \"unique_id\": \"byd_car_turnoff_aircondition\",\n            \"icon\": \"mdi:hvac-off\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_light_alert/config\",\n        \"payload\": {\n            \"name\": \"byd_car_light_alert\",//闪灯鸣笛\n            \"command_topic\": `${prefix}/light_alert/control`,\n            \"payload_press\": \"D3D9446802A44259755D38E6D163E820\",\n            \"unique_id\": \"byd_car_light_alert\",\n            \"icon\": \"mdi:bugle\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_close_window/config\",\n        \"payload\": {\n            \"name\": \"byd_car_close_window\",//关闭车窗\n            \"command_topic\": `${prefix}/close_window/control`,\n            \"payload_press\": \"70EFDF2EC9B086079795C442636B55FB\",\n            \"unique_id\": \"byd_car_close_window\",\n            \"icon\": \"mdi:car-select\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/button/byd_car_flash_light/config\",\n        \"payload\": {\n            \"name\": \"byd_car_flash_light\",//闪灯\n            \"command_topic\": `${prefix}/flash_light/control`,\n            \"payload_press\": \"B6D767D2F8ED5D21A44B0E5886680CB9\",\n            \"unique_id\": \"byd_car_flash_light\",\n            \"icon\": \"mdi:car-light-alert\"\n        }\n    }, \n    {\n        \"topic\": \"homeassistant/button/byd_car_seat_heat/config\",\n        \"payload\": {\n            \"name\": \"byd_car_seat_heat\",//座椅通风加热\n            \"command_topic\": `${prefix}/seat_heat/control`,\n            \"payload_press\": \"4E732CED3463D06DE0CA9A15B6153677\",\n            \"unique_id\": \"byd_car_seat_heat\",\n            \"icon\": \"mdi:car-seat-heater\"\n        }\n    },\n    {\n        \"topic\": \"homeassistant/switch/byd_car_trunk/config\",\n        \"payload\": {\n            \"~\": prefix.replace(\"button\", \"switch\"),\n            \"name\": \"byd_car_trunk\",//后备箱\n            \"state_topic\": \"~/trunk/state\",\n            \"command_topic\": \"~/trunk/control\",\n            \"payload_on\": \"1679091C5A880FAF6FB5E6087EB1B2DC\",\n            \"payload_off\": \"1C383CD30B7C298AB50293ADFECB7B18\",\n            \"state_on\": 1,\n            \"state_off\": 0,\n            \"unique_id\": \"byd_car_trunk\",\n            \"icon\": \"mdi:car-back\"\n        }\n    },\n    {\n        \"topic\": `${prefix.replace(\"button\", \"switch\")}/trunk/state`,\n        \"payload\": car_info.hbx\n    },\n    {\n        \"topic\": `${prefix.replace(\"button\", \"sensor\")}/state`,\n        \"payload\": car_info.ok == 1 ? \"启动\" : \"熄火\"\n    },\n    {\n        \"topic\": `${prefix.replace(\"button\", \"sensor\")}/info`,\n        \"payload\": car_info\n    },\n    {\n        \"topic\": `${prefix.replace(\"button\", \"sensor\")}/zczt/state`,\n        \"payload\": car_info.zczt\n    },\n    {\n        \"topic\": `${prefix.replace(\"button\", \"binary_sensor\")}/cmzq/state`,\n        \"payload\": car_info.cmzq\n    }\n]\n\nreturn [msg_config];\n",
