        "func": "let commandType = flow.get(\"bydApiPayload\")\nconst cmdList = [\"1C383CD30B7C298AB50293ADFECB7B18\", \"1679091C5A880FAF6FB5E6087EB1B2DC\"]\nif(commandType && msg.payload.data > 1){\n    if (commandType in cmdList){\n        msg.topic = \"home/swtich/byd_car/trunk/state\"\n        msg.payload = commandType == cmdList[1] ? 1 : 0\n        \n        return msg\n    }\n}",
