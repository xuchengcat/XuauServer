    {
        "id": "166b3f65980aab2e",
        "type": "function",
        "z": "2524e973a45d6f57",
        "name": "Check_WorkDay",
        "func": "let now = new Date();\nlet year = now.getFullYear();\nlet month = now.getMonth() + 1; // JavaScript 的月份从 0 开始，需要 +1\nlet day = now.getDate();\n// 生成目标 URL\nlet url = `https://tiansh.github.io/gzr/${year}/${month}/${day}.json`;\nmsg.url = url; // 将 URL 赋值给 msg.url 传递给下一个节点\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 110,
        "y": 920,
        "wires": [
            []
        ]
    },
