    {
        "id": "a3b6acd3e2f2c2a5",
        "type": "function",
        "z": "2524e973a45d6f57",
        "name": "Battery Check",
        "func": "let sensors = msg.payload; // 获取传感器数组\nlet minValue = Infinity;\nlet minSensor = null;\n\nfor (let i = 0; i < sensors.length; i++) {\n    const sensor = sensors[i];\n    const value = parseFloat(sensor.state); // 获取传感器的状态值\n\n    // 检查状态是否小于 20\n    if (value < 20) {\n        msg.payload = `${sensor.attributes.friendly_name} 低: ${value}`;\n        return msg; // 立即返回消息通知\n    }\n    \n    // 更新最小值\n    if (value < minValue) {\n        minValue = value;\n        minSensor = sensor.attributes.friendly_name;\n    }\n}\n\n// 如果所有传感器的状态都大于 20，返回最小的值\nif(minValue<40){\nmsg.payload = `${minSensor} 较低: ${minValue}`;\n}else{\nmsg.payload = ``;\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 1240,
        "wires": [
            [
                "286ca84e04f7d674"
            ]
        ]
    },
