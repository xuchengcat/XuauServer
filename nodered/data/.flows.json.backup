    {
        "id": "010b52d52526266f",
        "type": "function",
        "z": "2524e973a45d6f57",
        "name": "Bark通知",
        "func": "// Bark 服务器和 Token\nconst BARK_SERVER = \"xuau-bark-server.onrender.com\";\nconst BARK_TOKEN = \"iphone\"; // 你的设备 token\n\n// 通知标题和内容\nconst title =  `服务器温度过高，已到${msg.payload}°C`;; // 你可以自定义内容\n\n// group参数可选\nconst group = \"Server\";\n\n// 构造 Bark 通知 URL\nconst url = `https://${BARK_SERVER}/${BARK_TOKEN}/${encodeURIComponent(title)}?group=${encodeURIComponent(group)}`;\n\n// 设置 HTTP request 节点需要的参数\nmsg.method = \"GET\";\nmsg.url = url;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 1400,
        "wires": [
            [
                "80d25819207ffa35"
            ]
        ]
    },
