        "type": "function",
        "z": "783a4e34d3609ab4",
        "name": "API参数",
        "func": "let userInfo = global.get(\"bydUserInfo\");\nlet msgType = typeof (msg.payload)\nif (userInfo) {\n    msg.headers = {};\n    msg.headers['Content-Type'] = 'application/json';\n    msg.headers['cookie'] = userInfo.cookies;\n    msg.payload = `{\"caridentifier\": \"${userInfo.vin}\",\"random\":\"${global.get(\"uuid\")}\",\"autoType\":\"${userInfo.autoType}\",\"energyType\":${userInfo.energyType}, \"timeStamp\": ${Math.floor(Date.now())}}`\n    if (msgType === \"number\"){\n        return [msg, null]\n    } else {\n        return [null, msg]\n    }\n}",
