    {
        "id": "0e9b70297b8d20cc",
        "type": "function",
        "z": "783a4e34d3609ab4",
        "name": "API参数",
        "func": "let userInfo = global.get(\"bydUserInfo\");\nconst commandPwd = \"D09*************17B26FB8E2298F\" //控制密码的MD5大写值\nlet apiPayload = msg.payload\nif (userInfo) {\n    msg.headers = {};\n    msg.headers['Content-Type'] = 'application/json';\n    msg.headers['cookie'] = userInfo.cookies\n    let basic_payload = { \"caridentifier\": userInfo.vin, \"random\": global.get(\"uuid\"),\"timeStamp\": Math.floor(Date.now()) }\n    if (typeof (apiPayload) === \"string\") {\n        if (apiPayload == \"ECCBC87E4B5CE2FE28308FD9F2A7BAF3\") {\n            basic_payload.appendParam = 26;\n        }\n        if (apiPayload != \"E4DA3B7FBBCE2345D7772B0674A318D5\"){\n            basic_payload.commandPwd = commandPwd\n            basic_payload.commandType = apiPayload\n            flow.set(\"bydApiPayload\", apiPayload);\n            msg.payload = JSON.stringify(basic_payload)\n            return [msg, null]\n        }\n    } else {\n        if (0 == apiPayload.rebackResult){\n            basic_payload.requestSerial = apiPayload.requestSerial\n            basic_payload.commandType = flow.get(\"bydApiPayload\")\n            msg.payload = JSON.stringify(basic_payload)\n            return [null, msg]\n        }\n    }\n}",
        "outputs": 2,
        "noerr": 0,
